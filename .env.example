# Bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Target aggregator channel — username (e.g. @my_agg) or numeric ID (required)
TELEGRAM_AGGREGATOR_CHANNEL=

# Comma-separated list of Telegram user IDs allowed to manage channels via bot commands (required)
ALLOWED_USER_IDS=

# Path to the text file storing channel list, one per line (default: channels.txt)
CHANNELS_FILE=channels.txt

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Fetch mode: "polling" (default) or "event" (in development)
FETCH_MODE=polling

# Polling interval in milliseconds (default:300000 = 5 min)
POLL_INTERVAL_MS=300000

# Path to the JSON file storing last seen message IDs per channel (default: channel-state.json)
CHANNEL_STATE_FILE=channel-state.json

# --- MTProto credentials (only needed for FETCH_MODE=event, currently in development) ---
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_STRING_SESSION=
