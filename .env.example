# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# StringSession for the reader account (generate via GramJS auth script)
TELEGRAM_STRING_SESSION=

# Bot token for the writer (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Target aggregator channel — username (e.g. @my_agg) or numeric ID
TELEGRAM_AGGREGATOR_CHANNEL=

# Comma-separated list of source channel usernames or IDs to monitor
SOURCE_CHANNELS=

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Fetch mode: "event" for real-time NewMessage listener, "polling" for periodic polling (default: event)
FETCH_MODE=event

# Polling interval in milliseconds, used only when FETCH_MODE=polling (default: 900000 = 15 min)
POLL_INTERVAL_MS=900000

# Path to the JSON file storing last seen message IDs per channel, used only when FETCH_MODE=polling (default: channel-state.json)
CHANNEL_STATE_FILE=channel-state.json